# Copy to `.env.local` and fill in as needed.

# ── AI Portfolio Assistant ──────────────────────────────────────────────
# OpenRouter API key (server-only — never NEXT_PUBLIC). Required for the assistant.
OPENROUTER_API_KEY=
# Any OpenRouter model slug (copy the exact id from the model's page on OpenRouter).
# Default: Qwen3 Coder 480B A35B (free). Free models have low rate limits.
# Other options: openai/gpt-4o-mini · anthropic/claude-3.5-haiku · meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL=qwen/qwen3-coder:free

# Generative-UI tools (rich cards/diagrams in answers). Requires a model that
# supports tool-calling. Many :free models don't → leave off for those.
# Set to "on" only with a tools-capable model.
ASSISTANT_TOOLS=off

# Vector store backend: "memory" (default, reads data/knowledge.json) or "upstash".
VECTOR_STORE=memory
# Only needed when VECTOR_STORE=upstash:
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# Optional distributed rate limiting (falls back to in-memory when unset):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Site / SEO ──────────────────────────────────────────────────────────
# Canonical origin (no trailing slash). Used for SEO, sitemap, JSON-LD.
NEXT_PUBLIC_SITE_URL=

# ── Analytics (opt-in; nothing loads unless set) ────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_VERCEL_ANALYTICS=
